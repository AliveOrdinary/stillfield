---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Stillfield — non-sensory calm pods for spas, hotels & workplaces',
  description = 'Non-sensory pods that deliver deep calm in 15–30 minutes. Designed for spas, wellness centres, hotels, and forward-thinking workplaces. Register your interest.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL('/og.jpg', Astro.site).toString();
---
<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index,follow" />
  <meta name="theme-color" content="#060607" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="en_GB" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://stillfield.co/#org",
        "name": "Stillfield",
        "url": "https://stillfield.co",
        "logo": {
          "@type": "ImageObject",
          "url": "https://stillfield.co/favicon.svg"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "Partner enquiries",
          "email": "hello@stillfield.co"
        }
      },
      {
        "@type": "WebSite",
        "@id": "https://stillfield.co/#website",
        "url": "https://stillfield.co",
        "name": "Stillfield",
        "publisher": { "@id": "https://stillfield.co/#org" }
      },
      {
        "@type": "Service",
        "@id": "https://stillfield.co/#service",
        "name": "Stillfield non-sensory calm pods",
        "description": "Non-sensory pods that deliver deep calm in 15–30 minutes, designed for spas, wellness centres, hotels, and workplaces.",
        "provider": { "@id": "https://stillfield.co/#org" },
        "areaServed": "Worldwide",
        "audience": {
          "@type": "Audience",
          "audienceType": "Spas, wellness centres, hotels, and workplaces"
        }
      }
    ]
  })} />

  <slot name="head" />
</head>
<body>
  <slot />
</body>
</html>
