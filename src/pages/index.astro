---
import Base from '../layouts/Base.astro';
import Mark from '../components/Mark.astro';
import Modal from '../components/Modal';
import Sound from '../components/Sound';
import '../styles/global.css';
import '../styles/modal.css';
---
<Base>
  <Fragment slot="head">
    <link rel="preload" href="/fonts/tenor-sans-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/hanken-grotesk-300.woff2" as="font" type="font/woff2" crossorigin />
  </Fragment>

  <h1 class="sr-only">Stillfield — non-sensory calm pods for spas, hotels &amp; workplaces</h1>

  <main class="stage">
    <!-- The noise of the world: restless grain filling the viewport.
         Pure CSS/SVG, decorative only; all real content is in the band below. -->
    <div class="field" aria-hidden="true">
      <div class="field-churn"></div>
      <div class="field-grain"></div>
      <div class="field-vignette"></div>
    </div>

    <header class="topbar">
      <a href="/" class="brand" aria-label="Stillfield home">
        <Mark />
        <span class="wordmark">STILLFIELD</span>
      </a>
      <button class="sound-toggle" data-sound type="button" aria-label="Toggle ambient sound" aria-pressed="false" hidden>
        <svg class="snd snd-on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
          <path d="M4 9v6h3l5 4V5L7 9H4z" fill="currentColor" stroke="none"/>
          <path d="M16 8.5a5 5 0 0 1 0 7"/>
          <path d="M18.5 6a8.5 8.5 0 0 1 0 12"/>
        </svg>
        <svg class="snd snd-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
          <path d="M4 9v6h3l5 4V5L7 9H4z" fill="currentColor" stroke="none"/>
          <path d="M16 9.5l5 5M21 9.5l-5 5"/>
        </svg>
      </button>
    </header>

    <!-- The silence: one perfectly still band where the noise stops. -->
    <section class="band">
      <h2 class="lede">A space where the noise ends.</h2>
      <p class="band-copy">Non-sensory pods that deliver deep calm in 15&ndash;30 minutes. Designed for spas, wellness centres, hotels, and forward-thinking workplaces.</p>
      <button class="register" data-cta aria-haspopup="dialog">Register Interest</button>
    </section>
  </main>

  <Modal client:idle />
  <Sound client:idle />
</Base>
